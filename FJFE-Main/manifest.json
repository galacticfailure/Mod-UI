{
  "manifest_version": 3,
  "name": "FJ Feature Extender",
  "description": "Bunch of helper stuff.",
  "version": "0.4.0",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://funnyjunk.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://funnyjunk.com/*"
      ],
      "js": [
        "content/apichk.js",
        "content/info.js",
        "content/sel.js",
        "content/slick.js",
        "content/modjs.js",
        "content/ratetrack.js",
        "content/sccustom.js",
        "content/userpop.js",
        "content/nextmove.js",
        "content/remtz.js",
        "content/rclick.js",
        "content/textcheck.js",
        "content/walcorn.js",
        "content/funnyjunkModifier.js",
        "content/clicker.js",
        "content/repost_clicker/rcinfo.js",
        "content/repost_clicker/rcprod.js",
        "content/repost_clicker/rcmain.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "FJ Feature Extender"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/admin_whispering.png",
        "icons/agi_shitposter.png",
        "icons/auto_scheduler.png",
        "icons/award.png",
        "icons/bait_vectrohex.png",
        "icons/ban_evade.png",
        "icons/bot.png",
        "icons/botnet.png",
        "icons/breach_containment.png",
        "icons/bribe_bluename.png",
        "icons/click.png",
        "icons/comments_content.png",
        "icons/deploy_jettom.png",
        "icons/digital_clones.png",
        "icons/discord_scraper.png",
        "icons/down_icon.png",
        "icons/extra_monitor.png",
        "icons/extra_tab.png",
        "icons/faster_wi-fi.png",
        "icons/fjinfo.png",
        "icons/full_reset.png",
        "icons/funnyjunk_2.png",
        "icons/hehe.png",
        "icons/hidden.png",
        "icons/hire_jeets.png",
        "icons/hire_marlboros.png",
        "icons/hornybait.png",
        "icons/icon128.png",

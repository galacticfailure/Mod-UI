{
  "manifest_version": 3,
  "name": "FJFE",
  "description": "Bunch of helper stuff.",
  "version": "0.5.0",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://funnyjunk.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://funnyjunk.com/*"
      ],
      "js": [
        "content/apichk.js",
        "content/info.js",
        "content/sel.js",
        "content/slick.js",
        "content/modjs.js",
        "content/ratetrack.js",
        "content/sccustom.js",
        "content/userpop.js",
        "content/nextmove.js",
        "content/remtz.js",
        "content/rclick.js",
        "content/textcheck.js",
        "content/walcorn.js",
        "content/warn.js",
        "content/funnyjunkModifier.js",
        "content/repost_clicker/rcinfo.js",
        "content/repost_clicker/rcsettings.js",
        "content/repost_clicker/rcstats.js",
        "content/repost_clicker/rcstore.js",
        "content/repost_clicker/rcprod.js",
        "content/repost_clicker/rcmain.js",
        "content/repost_clicker/rcdebug.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "FJ Feature Extender"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "icons/clicker/*",
        "icons/clicker/production/*",
        "icons/clicker/upgrades/*"
      ],
      "matches": [
        "https://funnyjunk.com/*"
      ]
    }
  ]
}

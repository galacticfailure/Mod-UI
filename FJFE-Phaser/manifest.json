{
    "manifest_version": 2,
    "name": "Phaser FJ Feature Extender",
    "description": "Bunch of helper stuff.",
    "version": "0.5.0",
    "browser_specific_settings": {
        "gecko": {
            "id": "phaser-fj-tweaker@nonsense.com",
            "strict_min_version": "74.0"
        }
    },
    "permissions": [
        "storage",
        "contextMenus",
        "https://funnyjunk.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://funnyjunk.com/*"
            ],
            "js": [
                "content/apichk.js",
                "content/info.js",
                "content/sel.js",
                "content/slick.js",
                "content/modjs.js",
                "content/ratetrack.js",
                "content/sccustom.js",
                "content/userpop.js",
                "content/nextmove.js",
                "content/remtz.js",
                "content/rclick.js",
                "content/textcheck.js",
                "content/walcorn.js",
                "content/warn.js",
                "content/funnyjunkModifier.js",
                "content/repost_clicker/rcinfo.js",
                "content/repost_clicker/rcsettings.js",
                "content/repost_clicker/rcstats.js",
                "content/repost_clicker/rcstore.js",
                "content/repost_clicker/rcprod.js",
                "content/repost_clicker/rcmain.js",
                "content/repost_clicker/rcdebug.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "browser_action": {
        "default_title": "Phaser FJ Feature Extender"
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "icons": {
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        "icons/*",
        "icons/clicker/*",
        "icons/clicker/production/*",
        "icons/clicker/upgrades/*"
    ]
}